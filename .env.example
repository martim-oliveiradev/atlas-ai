# Copy to .env and fill in.

# Prisma. Local dev uses SQLite. Production: point at Postgres and set
# provider = "postgresql" in prisma/schema.prisma, then `npx prisma db push`.
DATABASE_URL="file:./dev.db"

# Required. Generate with: openssl rand -base64 32
AUTH_SECRET=""

# Optional. Without a key the app runs in demo mode and serves a built-in
# sample itinerary instead of calling the AI. Free key (no card) from
# https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=""
GEMINI_MODEL="gemini-flash-lite-latest"

# The trip map uses Leaflet + free Carto dark tiles: no key, no account needed.
